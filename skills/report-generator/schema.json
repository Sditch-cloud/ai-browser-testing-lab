{
  "name": "report-generator",
  "version": "1.0.0",
  "description": "Generate HTML and JSON test reports from accumulated log entries.",
  "parameters": {
    "type": "object",
    "required": ["testName", "logs"],
    "properties": {
      "testName": {
        "type": "string",
        "description": "Name of the test that was executed"
      },
      "metadata": {
        "type": "object",
        "description": "Test case metadata (from parse-testcase output)"
      },
      "logs": {
        "type": "array",
        "description": "Array of log entries produced by log-recorder during the run",
        "items": { "type": "object" }
      },
      "outputDir": {
        "type": "string",
        "description": "Directory to write reports into",
        "default": "reports"
      }
    }
  },
  "returns": {
    "type": "object",
    "properties": {
      "jsonPath": { "type": "string", "description": "Path to the JSON report file" },
      "htmlPath": { "type": "string", "description": "Path to the HTML report file" },
      "summary": {
        "type": "object",
        "properties": {
          "total": { "type": "number" },
          "passed": { "type": "number" },
          "failed": { "type": "number" },
          "skipped": { "type": "number" },
          "duration": { "type": "number", "description": "Total duration in milliseconds" }
        }
      }
    }
  }
}
